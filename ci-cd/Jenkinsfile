pipeline {
    agent any

    options {
        timestamps()
    }

    stages {

        stage('Checkout') {
            steps {
                echo 'Pulling latest code from GitHub...'
                checkout scm
            }
        }

        stage('Run Tests') {
            steps {
                dir('backend') {
                    echo '🧪 Running backend tests and generating JaCoCo reports (will enforce 70% threshold)'
                    // Run tests, generate jacoco report and check coverage. jacoco:check will fail the build
                    // if the coverage rules in the POM are not met (configured at 70%).
                    bat 'set MAVEN_OPTS="-Xmx256m" && mvn -f pom.xml clean test -B -Dnet.bytebuddy.experimental=true'
                }
                // Publish JUnit test results so Jenkins can show test trends
                junit allowEmptyResults: true, testResults: 'backend/**/target/surefire-reports/*.xml'
                // Archive JaCoCo xml and HTML reports for later inspection
                archiveArtifacts artifacts: 'backend/**/target/site/jacoco/**', allowEmptyArchive: true
            }
        }

        stage('Build Jars') {
            steps {
                dir('backend') {
                    echo '🔨 Building backend jars (reactor mvn package)...'
                    bat 'set MAVEN_OPTS="-Xmx256m" && mvn clean package -DskipTests -B -Dnet.bytebuddy.experimental=true'
                }
            }
        }

        stage('Stop Existing Containers') {
            steps {
                bat 'docker compose -f ci-cd/docker-compose.yml down --remove-orphans'
            }
        }

        stage('Build Fresh Images') {
            steps {
                bat 'docker compose -f ci-cd/docker-compose.yml build --no-cache'
            }
        }

        stage('Start Containers') {
            steps {
                bat 'docker compose -f ci-cd/docker-compose.yml up -d'
            }
        }

        stage('Verify Deployment') {
            steps {
                bat 'docker compose -f ci-cd/docker-compose.yml ps'
            }
        }
    }

    post {
        success {
            echo 'SMS deployed successfully'
        }

        failure {
            echo 'SMS deployment failed'
        }
    }
}