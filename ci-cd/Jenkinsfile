pipeline {
    agent any

    options {
        timestamps()
    }

    environment {
        DOCKER_BUILDKIT = '0'   // Disable BuildKit (helps avoid EOF issues)
    }

    stages {

        stage('Checkout') {
            steps {
                echo 'Pulling latest code from GitHub...'
                checkout scm
            }
        }

        stage('Build Backend JARs') {
            steps {
                dir('backend') {
                    bat 'mvn clean package -DskipTests -B'
                }
            }
        }

        stage('Stop Existing Containers') {
            steps {
                bat 'docker compose -f ci-cd/docker-compose.yml down --remove-orphans'
            }
        }

        stage('Clean Docker Builder') {
            steps {
                bat 'docker builder prune -af'
            }
        }

        stage('Build Docker Images') {
            steps {
                bat 'docker compose -f ci-cd/docker-compose.yml build --progress=plain --no-cache'
            }
        }

        stage('Start Containers') {
            steps {
                bat 'docker compose -f ci-cd/docker-compose.yml up -d'
            }
        }

        stage('Verify Deployment') {
            steps {
                bat 'docker compose -f ci-cd/docker-compose.yml ps'
            }
        }
    }

    post {
        always {
            bat 'docker image prune -f'
        }

        success {
            echo 'SMS deployed successfully'
        }

        failure {
            echo 'SMS deployment failed'
            bat 'docker compose -f ci-cd/docker-compose.yml logs'
        }
    }
}